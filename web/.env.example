# Supabase (required — auth and DB still use Supabase)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Feature flag: set to "true" to use Python backend, "false" to use Supabase Edge Functions
VITE_USE_PYTHON_BACKEND=false
VITE_PYTHON_BACKEND_URL=http://localhost:8000

# Optional: fallback Groq key for the browser (not recommended for production)
VITE_GROQ_API_KEY=

{
  "name": "domino-ui",
  "version": "0.2.1",
  "description": "JSON-to-React UI renderer for AI-generated layouts",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup"
  },
  "peerDependencies": {
    "react": ">=18",
    "recharts": ">=2",
    "lucide-react": ">=0.4",
    "clsx": ">=2",
    "tailwind-merge": ">=2"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "tsup": "^8.5.0",
    "typescript": "~5.8.3"
  }
}
